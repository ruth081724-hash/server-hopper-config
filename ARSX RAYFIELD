RunService:BindToRenderStep("ArribaAbajo", Enum.RenderPriority.Last.Value, function()
    if not flying or not bodyVelocity then return end
    local vel = bodyVelocity.Velocity
    if goingUp then vel += Vector3.new(0,FLY_SPEED,0) end
    if goingDown then vel -= Vector3.new(0,FLY_SPEED,0) end
    bodyVelocity.Velocity = vel
end)

RunService:BindToRenderStep("Noclip", Enum.RenderPriority.Last.Value, function()
