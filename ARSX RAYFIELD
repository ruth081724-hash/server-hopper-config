-- HITBOX EXPANDER

_G.HitboxEnabled = false
_G.HitboxSize = 25
_G.HitboxTransparency = 0.5
_G.HitboxTeamCheck = false

local function ProcessHitbox()
    if not _G.HitboxEnabled then return end
    for _, v in pairs(Players:GetPlayers()) do
        if v == LP or not v.Character or not v.Character:FindFirstChild("Head") then continue end
        if _G.HitboxTeamCheck and v.Team == LP.Team then continue end
        local Head = v.Character.Head
        local Hum = v.Character:FindFirstChildOfClass("Humanoid")
        if Hum and Hum.Health > 0 then
            Head.Size = Vector3.new(_G.HitboxSize,_G.HitboxSize,_G.HitboxSize)
            Head.Transparency = _G.HitboxTransparency
            Head.CanCollide = false
            Head.Massless = true
        else
            Head.Size = Vector3.new(1,1,1)
            Head.Transparency = 0
        end
    end
end

RunService.RenderStepped:Connect(ProcessHitbox)

