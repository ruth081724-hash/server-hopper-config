local limbDropdown
local currentLimbs = {}

local function refreshLimbsDropdown()
    currentLimbs = {}
    local char = LocalPlayer.Character
    if char then
        for _, part in ipairs(char:GetChildren()) do
            if part:IsA("BasePart") and not table.find(currentLimbs, part.Name) then
                table.insert(currentLimbs, part.Name)
            end
        end
        table.sort(currentLimbs)
    end
    if limbDropdown then
        limbDropdown:Refresh(currentLimbs, true)
    end
end

limbDropdown = LimbsTab:CreateDropdown({
    Name = "Extremidad objetivo (Selecciona cuál extender)",
    Options = currentLimbs,
    CurrentOption = {le:Get("TARGET_LIMB") or "Head"},
    MultipleOptions = false,
    Callback = function(opt)
        le:Set("TARGET_LIMB", opt[1])
        Rayfield:Notify({Title="Extremidad Actualizada", Content="Objetivo: " .. opt[1], Duration=3})
    end
})

