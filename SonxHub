-- Draggable functionality (Improved)
local dragging = false
local dragStart = nil
local frameStart = nil

HeaderFrame.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = Mouse.Position
        frameStart = MainFrame.Position
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

Mouse.Move:Connect(function()
    if dragging and dragStart and frameStart then
        local delta = Mouse.Position - dragStart
        MainFrame.Position = frameStart + UDim2.new(0, delta.X, 0, delta.Y)
    end
end)

